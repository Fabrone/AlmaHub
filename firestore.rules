rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // USERS COLLECTION
    // ============================================
    match /Users/{userId} {
      allow get: if request.auth != null;
      allow list: if true;

      allow create: if request.auth != null &&
                       request.resource.data.uid == request.auth.uid &&
                       request.resource.data.role == 'Employee';

      allow update: if request.auth != null &&
                       (
                         (resource.data.uid == request.auth.uid &&
                          request.resource.data.role == resource.data.role) ||
                         request.auth != null
                       );

      allow delete: if request.auth != null;
    }

    // ============================================
    // DRAFT COLLECTION
    // ============================================
    match /Draft/{draftId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
                       (
                         resource.data.uid == request.auth.uid ||
                         request.auth != null
                       );
      allow delete: if request.auth != null;

      match /DailyHours/{dateKey} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null;
        allow delete: if request.auth != null;
      }
    }

    // ============================================
    // EMPLOYEE DETAILS COLLECTION
    // ============================================
    match /EmployeeDetails/{employeeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;

      match /DailyHours/{dateKey} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null;
        allow delete: if request.auth != null;
      }
    }

    // ============================================
    // SUPERVISORS COLLECTION
    // ============================================
    match /Supervisors/{supervisorId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.data.keys().hasAll(['fullname', 'email', 'department', 'uid']);
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ============================================
    // DEPARTMENTS COLLECTION
    // ============================================
    match /Departments/{departmentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.data.keys().hasAll(['name', 'members']);
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ============================================
    // HOURS FORWARDED COLLECTION
    // ============================================
    match /HoursForwarded/{forwardId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ============================================
    // RECRUITEES COLLECTION
    // ============================================
    match /Recruitees/{recruiteeId} {
      allow create: if request.resource.data.keys().hasAll(['fullName', 'email', 'cvUrl', 'submittedAt', 'status'])
                   && request.resource.data.fullName is string
                   && request.resource.data.email is string
                   && request.resource.data.email.matches('.*@.*[.].*')
                   && request.resource.data.cvUrl is string
                   && request.resource.data.status == 'pending';

      allow read: if true;

      allow update: if request.auth != null ||
                       (
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reviewedAt', 'reviewNotes', 'updatedAt'])
                       );

      allow delete: if true;
    }

    // ============================================
    // EMPLOYEE ONBOARDING COLLECTION
    // Covers the HREmployeeOnboardingScreen wizard
    // (both Draft saves and final EmployeeDetails submissions)
    // ============================================
    match /EmployeeOnboarding/{onboardingId} {
      // Any authenticated user (HR officer) can read onboarding records
      allow read: if request.auth != null;

      // HR creates new onboarding documents (draft or submitted)
      allow create: if request.auth != null;

      // HR can update at any stage (draft edits, status changes)
      allow update: if request.auth != null;

      // HR can delete draft records that were promoted to EmployeeDetails
      allow delete: if request.auth != null;
    }
  }
}
